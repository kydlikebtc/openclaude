# Database
DATABASE_URL=postgresql+asyncpg://openclaude:openclaude@localhost:5432/openclaude

# Redis
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS IN PRODUCTION
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32

# App settings
DEBUG=false
APP_NAME=OpenClade API

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------
# Monitoring & Alerting (Alertmanager)
# Start Alertmanager with: --config.expand-env=true
# to enable environment variable injection in alertmanager.yml
# ---------------------------------------------------------------

# PRIMARY: Default Slack webhook for all alerts (required)
# Get from: Slack App > Incoming Webhooks > Add New Webhook to Workspace
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Optional: Dedicated webhooks for specific channels.
# If not set, falls back to ALERT_WEBHOOK_URL.
ALERT_CRITICAL_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/CRITICAL/WEBHOOK
ALERT_BACKEND_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/BACKEND/WEBHOOK
ALERT_OPS_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/OPS/WEBHOOK

# Optional: Grafana base URL used in alert message links
GRAFANA_URL=http://localhost:3001
