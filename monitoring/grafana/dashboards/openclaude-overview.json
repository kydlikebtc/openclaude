{
  "annotations": {
    "list": []
  },
  "description": "OpenClaude System Overview — API, Miner Health, Token Consumption",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": "Prometheus",
        "definition": "label_values(openclaude_miner_heartbeat_age_seconds, miner_id)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "miner_id",
        "options": [],
        "query": {
          "query": "label_values(openclaude_miner_heartbeat_age_seconds, miner_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "label": "Miner ID",
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "title": "API Response Time (p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"openclaude-backend\"}[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Miner Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "id": 3,
      "title": "Active Miners (Pool Size)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size",
          "legendFormat": "Active Miners"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "id": 5,
      "title": "Miner Online Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size / openclaude_miner_total_registered",
          "legendFormat": "Online Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "title": "API Key Usage (req/s by key)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(openclaude_api_key_requests_total[5m])",
          "legendFormat": "{{key_id}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 6,
      "title": "Miner Online Rate Trend",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size / openclaude_miner_total_registered",
          "legendFormat": "Online Rate"
        },
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size",
          "legendFormat": "Pool Size"
        },
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_total_registered",
          "legendFormat": "Total Registered"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 360 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 7,
      "title": "Miner Heartbeat Age (seconds since last heartbeat)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_heartbeat_age_seconds{miner_id=~\"$miner_id\"}",
          "legendFormat": "Miner {{miner_id}} ({{hotkey}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 360 }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "id": 10,
      "title": "Miner Status Table (heartbeat age by miner)",
      "type": "table",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_heartbeat_age_seconds{miner_id=~\"$miner_id\"}",
          "instant": true,
          "legendFormat": "{{miner_id}}",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": false }],
        "footer": { "show": false }
      },
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": { "Value": "Heartbeat Age (s)" }
        }}
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 102,
      "title": "Token Consumption",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "axisCenteredZero": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "id": 8,
      "title": "Token Consumption Rate (tokens/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(openclaude_tokens_consumed_total[5m])",
          "legendFormat": "{{model}} ({{user_tier}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 9,
      "title": "Token Consumption Total (cumulative by model)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_tokens_consumed_total",
          "legendFormat": "{{model}} ({{user_tier}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["openclaude", "monitoring"],
  "title": "OpenClaude Overview",
  "uid": "openclaude-overview",
  "version": 3
}
