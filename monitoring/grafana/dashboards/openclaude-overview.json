{
  "annotations": {
    "list": []
  },
  "description": "OpenClaude System Overview — API, Miner Health, Token Consumption",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "API Response Time (p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"openclaude-backend\"}[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "title": "Active Miners (Pool Size)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size",
          "legendFormat": "Active Miners"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "id": 5,
      "title": "Miner Online Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size / openclaude_miner_total_registered",
          "legendFormat": "Online Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "API Key Usage (req/s by key)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(openclaude_api_key_requests_total[5m])",
          "legendFormat": "{{key_id}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "title": "Miner Online Rate Trend",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size / openclaude_miner_total_registered",
          "legendFormat": "Online Rate"
        },
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_pool_size",
          "legendFormat": "Pool Size"
        },
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_total_registered",
          "legendFormat": "Total Registered"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 360 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "title": "Miner Heartbeat Age (seconds since last heartbeat)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_miner_heartbeat_age_seconds",
          "legendFormat": "Miner {{miner_id}} ({{hotkey}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "axisCenteredZero": false }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "title": "Token Consumption Rate (tokens/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(openclaude_tokens_consumed_total[5m])",
          "legendFormat": "{{model}} ({{user_tier}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "title": "Token Consumption Total (cumulative by model)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "openclaude_tokens_consumed_total",
          "legendFormat": "{{model}} ({{user_tier}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["openclaude", "monitoring"],
  "title": "OpenClaude Overview",
  "uid": "openclaude-overview",
  "version": 2
}
