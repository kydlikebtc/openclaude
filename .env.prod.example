# ===================================================
# OpenClaude Production Environment Variables
# Copy this file to .env.prod and fill in real values
# NEVER commit .env.prod to version control
# ===================================================

# Database
POSTGRES_USER=openclaude
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=openclaude

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Application
DEBUG=false
APP_NAME=OpenClaude API

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=https://openclaude.io,https://www.openclaude.io

# Frontend
NEXT_PUBLIC_API_URL=https://api.openclaude.io

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_ROOT_URL=https://monitoring.openclaude.io
